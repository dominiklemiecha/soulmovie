{
  "name": "@soulmovie/api",
  "version": "0.1.0",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "lint": "echo skip",
    "test": "vitest run",
    "test:watch": "vitest",
    "migration:run": "ts-node --transpile-only --compiler-options {\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"Node\\\",\\\"experimentalDecorators\\\":true,\\\"emitDecoratorMetadata\\\":true,\\\"target\\\":\\\"ES2022\\\"} -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/infra/typeorm/data-source.ts migration:run",
    "migration:revert": "ts-node --transpile-only --compiler-options {\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"Node\\\",\\\"experimentalDecorators\\\":true,\\\"emitDecoratorMetadata\\\":true,\\\"target\\\":\\\"ES2022\\\"} -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/infra/typeorm/data-source.ts migration:revert",
    "seed": "ts-node --transpile-only --compiler-options {\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"Node\\\",\\\"experimentalDecorators\\\":true,\\\"emitDecoratorMetadata\\\":true,\\\"target\\\":\\\"ES2022\\\"} -r tsconfig-paths/register seeds/bootstrap-admin.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.7",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.7",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.7",
    "@nestjs/typeorm": "^10.0.2",
    "@soulmovie/shared": "workspace:*",
    "@types/multer": "^2.1.0",
    "argon2": "^0.40.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
