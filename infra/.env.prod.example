# Soulmovie production env (compila e usa come .env.prod su Dokploy)

# Domini
WEB_DOMAIN=soulmovie.connecteed.com
S3_DOMAIN=s3-soulmovie.connecteed.com

# Database
POSTGRES_USER=soulmovie_app
POSTGRES_PASSWORD=GENERA_STRINGA_LUNGA_E_RANDOM
POSTGRES_DB=soulmovie

# JWT (genera 2 stringhe diverse di 64+ caratteri)
JWT_ACCESS_SECRET=CHANGEME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGEME_OTHER_64_CHAR_RANDOM_STRING

# AES key (esattamente 64 caratteri hex)
SETTINGS_ENCRYPTION_KEY=CHANGEME_64_HEX_CHARS_FOR_AES_256

# MinIO
MINIO_ROOT_USER=soulmovie_admin
MINIO_ROOT_PASSWORD=CHANGEME_LUNGA_RANDOM
MINIO_BUCKET=soulmovie

# Bootstrap admin (creato al primo seed)
BOOTSTRAP_ADMIN_EMAIL=admin@soulmovie.connecteed.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGEME_PASSWORD_INIZIALE

# Immagini Docker (sostituisci con i tuoi tag/registry)
IMAGE_API=soulmovie-api:latest
IMAGE_WEB=soulmovie-web:latest
